{
  "name": "superava",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.0",
  "scripts": {
    "dev": "pnpm --parallel --filter @superava/api --filter @superava/web --filter @superava/worker dev",
    "dev:web": "pnpm --filter @superava/web dev",
    "dev:api": "pnpm --filter @superava/api dev",
    "dev:worker": "pnpm --filter @superava/worker dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@types/node": "^24.4.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
