NODE_ENV=production

API_HOST=127.0.0.1
API_PORT=4001
NEXT_PUBLIC_API_URL=https://superava.ru
WEB_ORIGIN=https://superava.ru,https://www.superava.ru
AUTH_PUBLIC_URL=https://superava.ru

SESSION_SECRET=replace-with-long-random-secret
TRUST_PROXY=true
READINESS_CHECK_STORAGE=true
READINESS_CHECK_WORKER=true
WORKER_HEARTBEAT_TTL_MS=20000
WORKER_HEARTBEAT_INTERVAL_MS=5000
GENERATION_STALE_TIMEOUT_MS=2700000

AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_ATTEMPTS=10
SESSION_MAX_AGE_SECONDS=2592000
EMAIL_VERIFICATION_TTL_HOURS=24
PASSWORD_RESET_TTL_MINUTES=30

DATABASE_URL=postgresql://superava:replace-postgres-password@127.0.0.1:5433/superava_prod

S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=replace-minio-access-key
S3_SECRET_KEY=replace-minio-password
S3_BUCKET=superava-assets

GEMINI_API_KEY=replace-gemini-key
RESEND_API_KEY=
MAIL_FROM=
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_SCOPE=login:email login:info
VK_CLIENT_ID=
VK_CLIENT_SECRET=
VK_SCOPE=vkid.personal_info email
MAILRU_CLIENT_ID=
MAILRU_CLIENT_SECRET=
MAILRU_AUTHORIZE_URL=
MAILRU_TOKEN_URL=
MAILRU_USERINFO_URL=
MAILRU_SCOPE=
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_NAME=
NEXT_PUBLIC_TELEGRAM_BOT_NAME=

ADMIN_EMAIL=admin@superava.ru
ADMIN_PASSWORD=replace-admin-password
DEV_USER_PASSWORD=replace-dev-password
